# Copy to .env and fill in. Local-dev defaults shown below.
#
# Local dev: `pnpm db:up` starts docker-compose — a Postgres + a local Neon
# HTTP/WS proxy. Keep NEON_LOCAL=true so the neon drivers target the proxy.
#
# Production (Neon cloud): unset NEON_LOCAL (or false); set DATABASE_URL to the
# POOLED Neon URL and DATABASE_URL_UNPOOLED to the DIRECT/unpooled Neon URL.

NEON_LOCAL=true

# Pooled connection — runtime app. Local default = docker Postgres (proxied).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/lugiajen

# Direct/unpooled connection — drizzle-kit migrate/generate.
DATABASE_URL_UNPOOLED=postgres://postgres:postgres@localhost:5432/lugiajen

# Better Auth — generate a secret with:  openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
# Also the base URL used to build links inside emails.
BETTER_AUTH_URL=http://localhost:3005

# Email (Resend). Optional — when unset, the app runs but sends nothing.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Lu Gia Jen <noreply@yourdomain.nl>

# Shared secret for the daily reminder cron (Authorization: Bearer ...).
# Vercel sends this header automatically when CRON_SECRET is set on the project.
# CRON_SECRET=replace-with-openssl-rand-base64-32

# Cloudflare Stream (video). Optional — the app runs without them; the Stream
# client throws a clear error if a Stream feature is used while unconfigured.
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# API token scoped to Stream:Edit.
# CLOUDFLARE_STREAM_API_TOKEN=your-stream-edit-token
# The customer-<CODE> code from your playback URLs.
# CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=customer-xxxxxxxx
# Signing key for self-signed playback tokens. Mint once via:
#   curl -s -X POST \
#     "https://api.cloudflare.com/client/v4/accounts/<ACCOUNT_ID>/stream/keys" \
#     -H "Authorization: Bearer <STREAM_API_TOKEN>"
# Copy result.id below, and result.pem (already base64) into the PEM var.
# CLOUDFLARE_STREAM_SIGNING_KEY_ID=key-id
# CLOUDFLARE_STREAM_SIGNING_KEY_PEM=base64-encoded-pem
# Secret used to verify Stream webhook signatures (wired in Session 2).
# CLOUDFLARE_STREAM_WEBHOOK_SECRET=replace-with-openssl-rand-base64-32
